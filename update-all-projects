#!/usr/bin/env bash
# ═══════════════════════════════════════════════════
# Forge — Update All Projects
# Recompiles the latest binary and hot-swaps it into
# every running Forge instance on the server.
#
# Since the dashboard is embedded via go:embed, updating
# the binary automatically updates the UI for all projects.
#
# Usage: ./update-all-projects
# ═══════════════════════════════════════════════════

set -e
export PATH="/usr/local/go/bin:$HOME/go/bin:$PATH"

SERVER_IP="${FORGE_SERVER_IP:-80.225.199.57}"
SERVER_USER="${FORGE_SERVER_USER:-ubuntu}"

echo ""
echo "  ⚡ Forge — Update All Projects"
echo "  ─────────────────────────────"
echo "  Server: $SERVER_IP"
echo ""

# Step 1: Build
echo "  [1/3] Building binary (linux/amd64)..."
GOOS=linux GOARCH=amd64 go build -ldflags="-w -s" -o forge-linux .
echo "        ✓ Built $(du -h forge-linux | cut -f1)"

# Step 2: Upload
echo "  [2/3] Uploading to server..."
scp -o StrictHostKeyChecking=no forge-linux $SERVER_USER@$SERVER_IP:/tmp/forge-update

# Step 3: Hot-swap all instances
echo "  [3/3] Updating all instances..."

ssh -o StrictHostKeyChecking=no $SERVER_USER@$SERVER_IP << 'EOF'

  UPDATED=0
  FAILED=0

  echo ""
  echo "  Scanning for running Forge services..."
  echo ""

  for SERVICE in $(systemctl list-units --type=service --state=running --no-legend | awk '{print $1}' | grep "^forge"); do
    SLUG=$(echo "$SERVICE" | sed 's/forge-//' | sed 's/\.service//')
    APP_DIR="/opt/forge/projects/$SLUG"

    # Main admin instance
    if [ "$SERVICE" = "forge.service" ]; then
      APP_DIR="/opt/forge"
    fi

    if [ -d "$APP_DIR" ]; then
      echo "  ↻ Updating: $SERVICE"

      # Stop → swap → start (prevents file-in-use errors)
      sudo systemctl stop "$SERVICE" 2>/dev/null || true
      sudo cp /tmp/forge-update "$APP_DIR/forge"
      sudo chmod +x "$APP_DIR/forge"
      sudo systemctl start "$SERVICE"

      sleep 1
      if systemctl is-active --quiet "$SERVICE"; then
        echo "    ✅ Online"
        UPDATED=$((UPDATED+1))
      else
        echo "    ❌ Failed — check: journalctl -u $SERVICE -n 20"
        FAILED=$((FAILED+1))
      fi
    else
      echo "  ⚠  Skipped $SERVICE (directory missing)"
    fi
  done

  rm -f /tmp/forge-update

  echo ""
  echo "  ─────────────────────────────"
  echo "  ✅ Updated: $UPDATED service(s)"
  if [ "$FAILED" -gt 0 ]; then
    echo "  ❌ Failed:  $FAILED service(s)"
  fi
  echo "  ─────────────────────────────"

EOF

# Cleanup
rm -f forge-linux

echo ""
echo "  🚀 All Forge instances updated!"
echo "  Admin: http://$SERVER_IP:8080/dashboard"
echo ""
