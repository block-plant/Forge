// forge.rules — Default security rules
// This is the production-safe starting point for a new Forge project.
// Tailor these rules before deploying to production.
//
// Rules version 2 — Forge DSL compatible.

rules_version = '2'

// ── Database Rules ────────────────────────────────────────────────────────────
service forge.database {
  match /databases/{database}/documents {

    // Users can only read and write their own user document.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Posts: anyone can read; only authenticated owners can create/edit/delete.
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.uid == request.auth.uid;
    }

    // Admin collection: only users with the admin custom claim can access.
    match /admin/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.admin == true;
    }

    // Everything else: deny by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ── Storage Rules ─────────────────────────────────────────────────────────────
service forge.storage {
  match /b/{bucket}/o/{allPaths=**} {
    // Public read, authenticated write.
    allow read:  if true;
    allow write: if request.auth != null;
  }

  // User-specific folders: only the user can write to their own folder.
  match /b/{bucket}/o/users/{userId}/{allPaths=**} {
    allow read:  if true;
    allow write: if request.auth != null && request.auth.uid == userId;
  }
}
