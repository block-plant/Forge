# ─────────────────────────────────────────────────────────────────
# Forge — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
FORGE_HOST=0.0.0.0
FORGE_PORT=8080

# ── Data ──────────────────────────────────────────────────────
FORGE_DATA_DIR=forge-data

# ── Logging ───────────────────────────────────────────────────
FORGE_LOG_LEVEL=info          # debug | info | warn | error
FORGE_LOG_PRETTY=true

# ── OAuth (Google) — get from https://console.cloud.google.com
FORGE_GOOGLE_CLIENT_ID=
FORGE_GOOGLE_CLIENT_SECRET=

# ── OAuth (GitHub) — get from https://github.com/settings/developers
FORGE_GITHUB_CLIENT_ID=
FORGE_GITHUB_CLIENT_SECRET=
