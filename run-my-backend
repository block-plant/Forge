#!/usr/bin/env bash
# ═══════════════════════════════════════════════════
# Forge — Run My Backend
# Deploys a new isolated Forge project instance
# to your server on the next available port.
#
# Usage: ./run-my-backend "My Project Name"
# ═══════════════════════════════════════════════════

set -e
export PATH="/usr/local/go/bin:$HOME/go/bin:$PATH"

if [ -z "$1" ]; then
  echo ""
  echo "  ⚡ Forge — Run My Backend"
  echo "  ─────────────────────────────"
  echo "  Usage: ./run-my-backend \"Project Name\""
  echo "  Example: ./run-my-backend \"Chat App\""
  echo ""
  exit 1
fi

PROJECT_NAME=$1
PROJECT_SLUG=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')

SERVER_IP="${FORGE_SERVER_IP:-80.225.199.57}"
SERVER_USER="${FORGE_SERVER_USER:-ubuntu}"

echo ""
echo "  ⚡ Forge — Run My Backend"
echo "  ─────────────────────────────"
echo "  Project: $PROJECT_NAME"
echo "  Slug:    $PROJECT_SLUG"
echo "  Server:  $SERVER_IP"
echo ""

# Step 1: Build (dashboard is embedded via go:embed)
echo "  [1/3] Building binary (linux/amd64)..."
GOOS=linux GOARCH=amd64 go build -ldflags="-w -s" -o forge-linux .
echo "        ✓ Built $(du -h forge-linux | cut -f1)"

# Step 2: Upload
echo "  [2/3] Uploading binary..."
scp -o StrictHostKeyChecking=no forge-linux $SERVER_USER@$SERVER_IP:/tmp/forge-new

# Step 3: Deploy on server
echo "  [3/3] Deploying $PROJECT_NAME..."
ssh -o StrictHostKeyChecking=no $SERVER_USER@$SERVER_IP "bash -s" -- "$PROJECT_SLUG" "$PROJECT_NAME" << 'EOF'
  SLUG="$1"
  NAME="$2"

  # Find first available port
  PORT=8081
  while ss -tuln | grep -q ":$PORT " ; do
    PORT=$((PORT+1))
  done

  if [ "$PORT" -gt 8100 ]; then
    echo "  ❌ No available ports (8081-8100). All slots full."
    exit 1
  fi

  echo "  ✓ Available port: $PORT"

  # Setup directories
  APP_DIR="/opt/forge/projects/$SLUG"
  DATA_DIR="/var/lib/forge-data/$SLUG"

  sudo mkdir -p "$APP_DIR" "$DATA_DIR"
  sudo chown -R ubuntu:ubuntu "$APP_DIR" "$DATA_DIR"

  # Move binary
  sudo mv /tmp/forge-new "$APP_DIR/forge"
  sudo chmod +x "$APP_DIR/forge"

  # Generate config
  cat <<JSON > "$APP_DIR/forge.json"
{
  "server": {
    "host": "0.0.0.0",
    "port": $PORT,
    "enable_cors": true,
    "cors_origins": ["*"]
  },
  "auth": { "enabled": true },
  "database": { "enabled": true },
  "storage": { "enabled": true },
  "hosting": { "enabled": true },
  "functions": { "enabled": true },
  "analytics": { "enabled": true },
  "data_dir": "$DATA_DIR"
}
JSON

  # Generate systemd service
  cat <<SERVICE | sudo tee /etc/systemd/system/forge-$SLUG.service > /dev/null
[Unit]
Description=Forge BaaS - $NAME
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=$APP_DIR
ExecStart=$APP_DIR/forge --config $APP_DIR/forge.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
SERVICE

  # Start service
  sudo systemctl daemon-reload
  sudo systemctl enable "forge-$SLUG"
  sudo systemctl restart "forge-$SLUG"

  # Open firewall
  sudo iptables -I INPUT 1 -p tcp --dport $PORT -j ACCEPT
  sudo netfilter-persistent save > /dev/null 2>&1 || true

  # Wait for it to come online
  sleep 2
  if systemctl is-active --quiet "forge-$SLUG"; then
    STATUS="✅ ONLINE"
  else
    STATUS="⚠️  Check logs: journalctl -u forge-$SLUG -n 20"
  fi

  SERVER_IP=$(curl -s ifconfig.me 2>/dev/null || echo "YOUR_SERVER_IP")

  echo ""
  echo "  ═══════════════════════════════════════════"
  echo "  🚀 PROJECT LAUNCHED: $NAME"
  echo "  ─────────────────────────────────────────────"
  echo "  Status:     $STATUS"
  echo "  API:        http://$SERVER_IP:$PORT"
  echo "  Dashboard:  http://$SERVER_IP:$PORT/dashboard"
  echo "  Service:    forge-$SLUG.service"
  echo "  Admin:      http://$SERVER_IP:8080/dashboard"
  echo "  ═══════════════════════════════════════════"
EOF

# Cleanup
rm -f forge-linux
echo ""
